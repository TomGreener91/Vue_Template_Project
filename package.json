{
  "name": "my-vue-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"**/*.{css,vue}\"",
    "lint:styles:fix": "stylelint \"**/*.{css,vue}\" --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "type-check": "vue-tsc --noEmit",
    "health": "node scripts/health-check.js",
    "release": "semantic-release",
    "deps:audit": "npm audit",
    "deps:outdated": "npm outdated",
    "deps:all": "npm run deps:audit && npm run deps:outdated",
    "deps:upgrade:minor": "npx npm-check-updates -u --target minor --peer && npm install",
    "deps:upgrade:latest": "npx npm-check-updates -u --peer && npm install",
    "deps:upgrade:interactive": "npx npm-check-updates -i --peer"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@greener-games/vite-csp": "^1.0.0",
    "@greener-games/vite-deterministic-port": "^1.0.0",
    "@greener-games/vite-screen-size": "^1.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "semantic-release": "^24.2.0",
    "stylelint": "^17.11.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.0"
  }
}
